{
  "name": "typescript-scaffold",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable TypeScript Node.js scaffold",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .husky",
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx,mts,cts}\" \"tests/**/*.{ts,tsx,mts,cts}\" \"vitest.config.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,mts,cts}\" \"tests/**/*.{ts,tsx,mts,cts}\" \"vitest.config.ts\" --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "oxfmt --check . && eslint \"src/**/*.{ts,tsx,mts,cts}\" \"tests/**/*.{ts,tsx,mts,cts}\" \"vitest.config.ts\" && vitest run && tsc --noEmit && tsc -p tsconfig.build.json"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts,jsx,tsx}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "lint-staged": "^15.4.3",
    "oxfmt": "^0.36.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
